---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

interface Course {
  title: string;
  href: string;
  image: string;
}

// const { courses } = Astro.props as { courses: Course[] };
const courses = [
  { title: "Ako strategicky pracovať s polarizáciou?",
    href: "/courses/course1",
    image: "https://storage.googleapis.com/dialogue-center/fotky%20agenti_%20/2024/Workshop%20-%20testovacia%20aktivita/462681844_1094981745547428_8236520902426863780_n.jpg"
  },
];
---

<Layout title="Dialogue center">
    <section class="w-full px-8 py-16">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-semibold text-[#102756] dark:text-white mb-2">
          Kurzy
        </h2>
        <div class="h-1 w-20 bg-gradient-to-r from-blue-500 to-emerald-500 mb-10 rounded-full"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {courses.map((course) => (
            <a
              href={course.href}
              class="group relative rounded-xl overflow-hidden shadow-md border border-gray-200 dark:border-gray-700 aspect-[4/3] block"
            >
              <!-- Background image -->

              <img
                src={course.image}
                alt={course.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />

              <!-- Blue gradient overlay: transparent top → blue bottom -->
              <div class="absolute inset-0 bg-gradient-to-t from-blue-900/85 via-blue-800/40 to-transparent transition-opacity duration-300 group-hover:opacity-90" />

              <!-- Content -->
              <div class="absolute bottom-0 left-0 right-0 p-5 flex flex-col gap-3">
                <h3 class="text-white text-xl font-semibold leading-snug drop-shadow">
                  {course.title}
                </h3>
                <span class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-200 group-hover:text-white transition-colors duration-200">
                  Zobraziť kurz
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>

              <!-- Subtle border glow on hover -->
              <div class="absolute inset-0 rounded-xl border-2 border-transparent group-hover:border-blue-500/40 transition-all duration-300 pointer-events-none" />
            </a>
          ))}
        </div>
      </div>
    </section>
</Layout>
